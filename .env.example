# 机密配置。复制成 .env 填写（.env 已被 .gitignore 忽略，不会提交）。
# 这里放「你在 config.yaml 的 dns.directive 里 {env.X} 引用的那些凭据」。
# PSK 和数据库密码会由 deploy.sh 自动生成并存到 .secrets，不用管。

# 默认（阿里云 DNS，需 AliyunDNSFullAccess 的 RAM AccessKey）：
ALIDNS_ACCESS_KEY_ID=
ALIDNS_ACCESS_KEY_SECRET=

# 换 Cloudflare 就删上面两行，改填：
# CF_API_TOKEN=
# 换 DNSPod：
# DNSPOD_TOKEN=
