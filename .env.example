# 机密配置。复制成 .env 填写（.env 已被 .gitignore 忽略，不会提交）。
# COOKIE_SECRET 由 deploy.sh 自动生成并存到 .secrets，不用管。

# ── GitHub OAuth App（申请制登录）──
# 在 https://github.com/settings/developers 建 OAuth App：
#   Homepage/Callback = https://<domain>:<public_port>/oauth2/callback
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ── 证书 DNS-01 凭据（按 config.yaml 的 dns.provider 填对应变量）──
# alidns（需 AliyunDNSFullAccess 的 RAM AccessKey）：
ALIDNS_ACCESS_KEY_ID=
ALIDNS_ACCESS_KEY_SECRET=
# cloudflare：CF_API_TOKEN=
# dnspod：    DNSPOD_TOKEN=
