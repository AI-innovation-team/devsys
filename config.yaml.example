# devsys 部署拓扑模板。复制为 config.yaml 再填自己的值：
#   cp config.yaml.example config.yaml && vim config.yaml
# config.yaml 已被 .gitignore 忽略（含内网拓扑，不入库）。机密另放 .env。
# 架构：用户 → relay(公网,纯转发) → 反向隧道 → gateway(内网,跑门户) → 各内网 server。

# ── 对外访问 ──
domain: coder.example.com           # 用户访问域名（A 记录指向 relay 公网 IP）
public_port: 8443                   # 对外端口（备案后可改 443）
acme_email: you@example.com         # Let's Encrypt 通知邮箱

# Caddy 容器访问外网用的代理（签证书需要）。留空=直连。
container_proxy: http://host.docker.internal:7890

# ── 证书 DNS-01 验证 ──
# provider: 内置支持 alidns / cloudflare / dnspod（凭据变量名见 .env.example）。
#           其它服务商：改 module + 在 scripts/render.py 的 DNS_BLOCKS 加对应 Caddy dns 块。
dns:
  provider: alidns
  module: github.com/caddy-dns/alidns

# ── 登录：GitHub OAuth，申请制白名单 ──
# client_id / client_secret 放 .env；这里只列非机密的白名单 GitHub 用户名。
# email_login: 额外开启邮箱+密码登录（国内更稳）。开启后用网关上的
#   add-email-user.sh 添加账号；至少加一个后才会真正生效（oauth2 不接受空表）。
oauth:
  provider: github
  github_users: [your-gh-username]
  email_login: true

# ── 公网中继（任意公网服务器）──
# ssh:  部署用 SSH 目标（~/.ssh/config 别名，或 user@host）
# user: 中继上的隧道专用账号（deploy 会创建）
# host: gateway 反向隧道要连的公网地址
relay:
  ssh: my-relay
  user: relay
  host: 203.0.113.10
  port: 22

# ── 网关（一台稳定内网机，跑门户，同时是 bastion）──
# ssh:  部署用 SSH 目标；user/home: 门户以该账号运行、文件放该 home 下
gateway:
  ssh: my-gateway
  user: ubuntu
  home: /home/ubuntu

# ── 内网服务器清单（门户里列出，供 SSH / VS Code / 工作区）──
# host/port: 内网地址与 SSH 端口
# jump:      可选。空=从 gateway 直连；填另一台 server 的 name=经它 ProxyJump。
servers:
  - { name: gpu-1, host: 10.0.0.11, port: 22 }
  - { name: gpu-2, host: 10.0.0.12, port: 22 }
  # 示例：某台只能经 gpu-1 跳板：
  # - { name: far, host: 10.0.0.99, port: 22, jump: gpu-1 }
