{
	# {$VAR} 由 Caddy 加载时从容器环境替换（简单值）
	email {$ACME_EMAIL}
	# 不占用 80 端口做跳转（避免触碰未备案域名的 80 端口拦截）
	auto_https disable_redirects
}

# 对外入口：https://{域名}:{端口}
https://{$DEV_DOMAIN}:{$PUBLIC_PORT} {
	# 证书用 DNS-01 验证，不需要 80 端口。
	# ── 换 DNS 服务商：改下面这个 dns 块 + config.yaml 的 dns.module ──
	# 各插件语法见其 README；凭据用 {env.X} 从 .env 注入的环境变量读取。
	tls {
		dns alidns {
			access_key_id {env.ALIDNS_ACCESS_KEY_ID}
			access_key_secret {env.ALIDNS_ACCESS_KEY_SECRET}
		}
	}
	reverse_proxy coder:7080
}
