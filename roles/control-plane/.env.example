# 角色 control-plane 的配置。复制成 .env 填好（.env 不提交）。
# 用 deploy.sh 时这个文件由编排器自动生成，无需手填；手动部署才用到。

# ── 对外访问 ──
DEV_DOMAIN=coder.psyagent.top        # 用户访问用的域名
PUBLIC_PORT=8443                     # 对外端口（备案后可改 443）
ACME_EMAIL=guohao2045@gmail.com      # 证书通知邮箱

# ── 数据库 & 置备器密钥 ──
POSTGRES_PASSWORD=change-me-strong
PROVISIONER_PSK=change-me-openssl-rand-hex-32   # 所有 node 一致

# ── 证书 DNS-01 验证 ──
CADDY_DNS_MODULE=github.com/caddy-dns/alidns   # Caddy 插件（换服务商改这里+Caddyfile）
# Caddyfile 的 tls dns 块用 {env.X} 引用的凭据：
ALIDNS_ACCESS_KEY_ID=your-access-key-id
ALIDNS_ACCESS_KEY_SECRET=your-access-key-secret

# ── 反向隧道 → 公网中继 ──
RELAY_HOST=39.97.7.248
RELAY_SSH_USER=relay
RELAY_SSH_PORT=22
