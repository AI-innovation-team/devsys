# 角色 node 的配置。每台内网机器一份，复制成 .env。
# 除 NODE_NAME 外，其余三项和控制面保持一致。

DEV_DOMAIN=coder.psyagent.top        # 和控制面一致
PUBLIC_PORT=8443                     # 和控制面一致
PROVISIONER_PSK=must-match-control-plane   # 和控制面一致

# 本机名字：随便起，但要唯一，并加进模板的机器清单（templates/gpu-container/machines.auto.tfvars）
# 例：lecun / fodor / hinton / turing
NODE_NAME=lecun
